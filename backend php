// 6. Obtener modelos por marca
function obtenerModelosPorMarca($id_marca) {
    global $conn;
    
    $id_marca = (int)$id_marca;
    
    $query = "SELECT id_modelo, nombre, año_desde, año_hasta 
              FROM modelos_auto 
              WHERE id_marca = $id_marca AND activa = TRUE 
              ORDER BY nombre";
    
    $result = $conn->query($query);
    $modelos = [];
    
    if ($result->num_rows > 0) {
        while ($row = $result->fetch_assoc()) {
            $modelos[] = $row;
        }
    }
    
    return $modelos;
}

// 7. Buscar productos
function buscarProductos($busqueda) {
    global $conn;
    
    $busqueda = $conn->real_escape_string($busqueda);
    
    $query = "SELECT p.*, c.nombre as categoria 
              FROM productos p 
              LEFT JOIN categorias c ON p.id_categoria = c.id_categoria 
              WHERE p.activo = TRUE AND (
                  p.nombre LIKE '%$busqueda%' 
                  OR p.codigo_parte LIKE '%$busqueda%' 
                  OR p.descripcion LIKE '%$busqueda%'
              ) 
              LIMIT 50";
    
    $result = $conn->query($query);
    $productos = [];
    
    if ($result->num_rows > 0) {
        while ($row = $result->fetch_assoc()) {
            $productos[] = $row;
        }
    }
    
    return $productos;
}

// 8. Crear pedido
function crearPedido($id_cliente, $items, $total) {
    global $conn;
    
    $id_cliente = (int)$id_cliente;
    $total = (float)$total;
    $numero_orden = 'ORD-' . date('YmdHis');
    
    $query = "INSERT INTO ordenes (numero_orden, id_cliente, total, estado) 
              VALUES ('$numero_orden', $id_cliente, $total, 'pendiente')";
    
    if ($conn->query($query)) {
        $id_orden = $conn->insert_id;
        
        // Insertar detalles
        foreach ($items as $item) {
            $id_producto = (int)$item['id_producto'];
            $cantidad = (int)$item['cantidad'];
            $precio = (float)$item['precio'];
            $subtotal = $cantidad * $precio;
            
            $query = "INSERT INTO detalles_orden (id_orden, id_producto, cantidad, precio_unitario, subtotal) 
                      VALUES ($id_orden, $id_producto, $cantidad, $precio, $subtotal)";
            
            $conn->query($query);
        }
        
        return ['id_orden' => $id_orden, 'numero_orden' => $numero_orden];
    }
    
    return false;
}

// RUTAS DE LA API

try {
    switch ($action) {
        case 'productos':
            echo json_encode(obtenerProductos($_GET));
            break;
            
        case 'producto':
            if (isset($_GET['id'])) {
                $producto = obtenerProductoPorId($_GET['id']);
                if ($producto) {
                    echo json_encode($producto);
                } else {
                    http_response_code(404);
                    echo json_encode(['error' => 'Producto no encontrado']);
                }
            }
            break;
            
        case 'productos_vehiculo':
            if (isset($_GET['modelo'])) {
                $tipo = isset($_GET['tipo']) ? $_GET['tipo'] : '';
                echo json_encode(obtenerProductosPorVehiculo($_GET['modelo'], $tipo));
            }
            break;
            
        case 'categorias':
            echo json_encode(obtenerCategorias());
            break;
            
        case 'marcas':
            echo json_encode(obtenerMarcas());
            break;
            
        case 'modelos':
            if (isset($_GET['marca'])) {
                echo json_encode(obtenerModelosPorMarca($_GET['marca']));
            }
            break;
            
        case 'buscar':
            if (isset($_GET['q'])) {
                echo json_encode(buscarProductos($_GET['q']));
            }
            break;
            
        case 'crear_pedido':
            if ($method === 'POST') {
                $datos = json_decode(file_get_contents('php://input'), true);
                $resultado = crearPedido($datos['cliente'], $datos['items'], $datos['total']);
                echo json_encode($resultado);
            }
            break;
            
        default:
            echo json_encode(['error' => 'Acción no especificada']);
    }
} catch (Exception $e) {
    http_response_code(500);
    echo json_encode(['error' => $e->getMessage()]);
}

$conn->close();
?>
