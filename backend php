<?php
// CONFIGURACIÓN DE CONEXIÓN A BASE DE DATOS
define('DB_HOST', 'localhost');
define('DB_USER', 'root');
define('DB_PASS', '');
define('DB_NAME', 'tienda_frenos');

// Conexión
try {
    $conn = new mysqli(DB_HOST, DB_USER, DB_PASS, DB_NAME);
    $conn->set_charset("utf8");
    
    if ($conn->connect_error) {
        throw new Exception("Error de conexión: " . $conn->connect_error);
    }
} catch (Exception $e) {
    http_response_code(500);
    echo json_encode(['error' => $e->getMessage()]);
    exit;
}

// CONFIGURAR HEADERS
header('Content-Type: application/json; charset=utf-8');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: GET, POST, PUT, DELETE');
header('Access-Control-Allow-Headers: Content-Type');

// OBTENER MÉTODO Y ACCIÓN
$method = $_SERVER['REQUEST_METHOD'];
$action = isset($_GET['action']) ? $_GET['action'] : '';

// FUNCIONES DE BASE DE DATOS

// 1. Obtener todos los productos
function obtenerProductos($filtros = []) {
    global $conn;
    
    $query = "SELECT p.*, c.nombre as categoria 
              FROM productos p 
              LEFT JOIN categorias c ON p.id_categoria = c.id_categoria 
              WHERE p.activo = TRUE";
    
    if (!empty($filtros['categoria'])) {
        $categoria = $conn->real_escape_string($filtros['categoria']);
        $query .= " AND c.nombre LIKE '%$categoria%'";
    }
    
    if (!empty($filtros['busqueda'])) {
        $busqueda = $conn->real_escape_string($filtros['busqueda']);
        $query .= " AND (p.nombre LIKE '%$busqueda%' OR p.codigo_parte LIKE '%$busqueda%')";
    }
    
    if (!empty($filtros['marca'])) {
        $marca = (int)$filtros['marca'];
        $query .= " AND p.id_producto IN (
                    SELECT id_producto FROM compatibilidad_producto_modelo 
                    JOIN modelos_auto ON compatibilidad_producto_modelo.id_modelo = modelos_auto.id_modelo 
                    WHERE modelos_auto.id_marca = $marca)";
    }
    
    $query .= " ORDER BY p.fecha_actualizacion DESC LIMIT 50";
    
    $result = $conn->query($query);
    $productos = [];
    
    if ($result->num_rows > 0) {
        while ($row = $result->fetch_assoc()) {
            $productos[] = $row;
        }
    }
    
    return $productos;
}

// 2. Obtener producto por ID
function obtenerProductoPorId($id) {
    global $conn;
    
    $id = (int)$id;
    $query = "SELECT p.*, c.nombre as categoria 
              FROM productos p 
              LEFT JOIN categorias c ON p.id_categoria = c.id_categoria 
              WHERE p.id_producto = $id AND p.activo = TRUE";
    
    $result = $conn->query($query);
    return $result->fetch_assoc();
}

// 3. Obtener productos por compatibilidad de vehículo
function obtenerProductosPorVehiculo($id_modelo, $tipo_repuesto = '') {
    global $conn;
    
    $id_modelo = (int)$id_modelo;
    
    $query = "SELECT DISTINCT p.*, c.nombre as categoria, cpm.posicion
              FROM productos p
              LEFT JOIN categorias c ON p.id_categoria = c.id_categoria
              LEFT JOIN compatibilidad_producto_modelo cpm ON p.id_producto = cpm.id_producto
              WHERE cpm.id_modelo = $id_modelo AND p.activo = TRUE";
    
    if (!empty($tipo_repuesto)) {
        $tipo = $conn->real_escape_string($tipo_repuesto);
        $query .= " AND c.nombre LIKE '%$tipo%'";
    }
    
    $query .= " ORDER BY c.nombre, p.nombre";
    
    $result = $conn->query($query);
    $productos = [];
    
    if ($result->num_rows > 0) {
        while ($row = $result->fetch_assoc()) {
            $productos[] = $row;
        }
    }
    
    return $productos;
}

